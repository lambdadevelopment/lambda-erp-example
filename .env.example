# Copy to .env and adjust. These are read by the core backend.

# Load this repo's plugin (acme/plugin.py register()). Comma-separated for more.
LAMBDA_ERP_PLUGINS=acme

# Where the SQLite database lives.
LAMBDA_ERP_DB=./acme.db

# Auto-seed demo data + a public_manager user on first boot (handy for a demo;
# set 0 for a clean private instance).
LAMBDA_ERP_AUTO_DEMO=0

# LLM keys for the chat features (optional for a static demo; required to drive
# the system via chat).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Frontend dev only: override the API base (defaults to same-origin "/api").
# VITE_API_BASE=http://localhost:8000/api
